rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "jh2006630@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidEcho(data) {
      let validEmotions = ['joy', 'sadness', 'relief', 'regret', 'peace'];
      let requiredFields = ['emotion', 'text', 'locationName', 'timestamp', 'x', 'y', 'lat', 'lng', 'uid'];
      let allowedFields = requiredFields.concat(['resonanceCount']);
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.emotion in validEmotions &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.locationName is string && data.locationName.size() > 0 && data.locationName.size() <= 100 &&
             data.timestamp is timestamp &&
             data.x is number && data.x >= 0 && data.x <= 100 &&
             data.y is number && data.y >= 0 && data.y <= 100 &&
             data.lat is number && data.lat >= -90 && data.lat <= 90 &&
             data.lng is number && data.lng >= -180 && data.lng <= 180 &&
             data.uid == request.auth.uid &&
             (!('resonanceCount' in data) || (data.resonanceCount is number && data.resonanceCount >= 0));
    }

    function isValidResonance(data) {
      return data.keys().hasAll(['uid', 'echoId', 'timestamp']) &&
             data.keys().hasOnly(['uid', 'echoId', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.echoId is string &&
             data.timestamp is timestamp;
    }

    match /echoes/{echoId} {
      allow get, list: if true;
      allow create: if isAuthenticated() && isValidEcho(request.resource.data);
      allow update: if isAuthenticated() && 
                      (isAdmin() || 
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resonanceCount']) &&
                        request.resource.data.resonanceCount == (resource.data.get('resonanceCount', 0)) + 1 &&
                        existsAfter(/databases/$(database)/documents/resonances/$(request.auth.uid + "_" + echoId))));
      allow delete: if isAdmin();
    }

    match /resonances/{resonanceId} {
      allow get: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      resonanceId == request.auth.uid + "_" + request.resource.data.echoId &&
                      isValidResonance(request.resource.data);
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) || isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
